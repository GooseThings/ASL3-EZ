[Unit]
Description=ASL3 rpt.conf Web Editor
After=network.target asterisk.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/asl3-rpt-editor
ExecStart=/opt/asl3-rpt-editor/venv/bin/python app.py
Restart=on-failure
RestartSec=5
Environment=PORT=5000
Environment=HOST=0.0.0.0
Environment=RPT_CONF_PATH=/etc/asterisk/rpt.conf
Environment=BACKUP_DIR=/etc/asterisk/rpt_backups
Environment=RESTART_CMD=systemctl restart asterisk

[Install]
WantedBy=multi-user.target
